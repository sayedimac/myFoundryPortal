<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Foundry Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyFoundryPortal.styles.css" asp-append-version="true" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="portal-body">

    <!-- Top header bar -->
    <header class="portal-header d-flex align-items-center px-3">
        <div class="d-flex align-items-center gap-2 me-auto">
            <span class="portal-logo">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#7c6fcd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            <span class="portal-brand">Microsoft Foundry</span>
            <span class="portal-separator">/</span>
            <span class="portal-project text-muted small">my-project</span>
        </div>
        <nav class="portal-top-nav d-none d-md-flex gap-3 align-items-center">
            <a href="#" class="portal-top-nav-link">Home</a>
            <a href="#" class="portal-top-nav-link">Discover</a>
            <a asp-controller="Home" asp-action="Index" class="portal-top-nav-link active">Build</a>
            <a href="#" class="portal-top-nav-link">Operate</a>
            <a href="https://learn.microsoft.com/en-us/azure/ai-services/agents/" target="_blank" class="portal-top-nav-link">Docs</a>
        </nav>
    </header>

    <div class="portal-shell d-flex">

        <!-- Left sidebar -->
        <nav class="portal-sidebar d-flex flex-column py-3" id="sidebarNav">
            <ul class="nav flex-column gap-1 px-2">
                <li class="nav-item">
                    <a class="portal-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agents" ? "active" : "")"
                       asp-controller="Agents" asp-action="Index">
                        <i class="bi bi-robot portal-nav-icon"></i>
                        <span class="portal-nav-label">Agents</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="portal-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Models" ? "active" : "")"
                       asp-controller="Models" asp-action="Index">
                        <i class="bi bi-grid portal-nav-icon"></i>
                        <span class="portal-nav-label">Models</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="portal-nav-link" href="#">
                        <i class="bi bi-tools portal-nav-icon"></i>
                        <span class="portal-nav-label">Tools</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="portal-nav-link" href="#">
                        <i class="bi bi-book portal-nav-icon"></i>
                        <span class="portal-nav-label">Knowledge</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="portal-nav-link" href="#">
                        <i class="bi bi-database portal-nav-icon"></i>
                        <span class="portal-nav-label">Data</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="portal-nav-link" href="#">
                        <i class="bi bi-bar-chart portal-nav-icon"></i>
                        <span class="portal-nav-label">Evaluations</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="portal-nav-link" href="#">
                        <i class="bi bi-shield-check portal-nav-icon"></i>
                        <span class="portal-nav-label">Guardrails</span>
                    </a>
                </li>
            </ul>
            <div class="mt-auto px-2">
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <a class="portal-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house portal-nav-icon"></i>
                            <span class="portal-nav-label">Dashboard</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main content -->
        <main class="portal-main flex-grow-1">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
