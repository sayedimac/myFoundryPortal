@model List<MyFoundryPortal.ViewModels.DeploymentViewModel>
@{
    ViewData["Title"] = "Models";
}

<div class="portal-page-header d-flex align-items-center justify-content-between">
    <div>
        <h1 class="portal-page-title"><i class="bi bi-grid me-2 text-muted"></i>Models</h1>
        <p class="text-muted small mb-0">Deployed models available in your Foundry project</p>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </a>
</div>

<div class="portal-page-content">

    @if (ViewData["Error"] != null)
    {
        <div class="alert alert-warning d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-triangle mt-1"></i>
            <div>
                <strong>Could not load models.</strong><br/>
                <span class="small text-muted">@ViewData["Error"]</span>
            </div>
        </div>
    }

    @if (Model.Count == 0 && ViewData["Error"] == null)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-grid display-4 d-block mb-3 opacity-25"></i>
            <p>No deployed models found in this project.</p>
        </div>
    }
    else if (Model.Count > 0)
    {
        <div class="bg-white rounded border">
            <table class="portal-table">
                <thead>
                    <tr>
                        <th>Deployment Name</th>
                        <th>Model</th>
                        <th>Version</th>
                        <th>Publisher</th>
                        <th>SKU</th>
                        <th>Capacity</th>
                        <th>Capabilities</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-name="@d.Name" class="fw-semibold text-decoration-none">
                                    @d.Name
                                </a>
                            </td>
                            <td>
                                <span class="portal-badge portal-badge-model">@d.ModelName</span>
                            </td>
                            <td class="text-muted small">@d.ModelVersion</td>
                            <td>
                                <span class="portal-badge portal-badge-publisher">@d.ModelPublisher</span>
                            </td>
                            <td class="text-muted small">@d.SkuName</td>
                            <td class="text-muted small">@(d.SkuCapacity > 0 ? d.SkuCapacity.ToString() : "–")</td>
                            <td>
                                @foreach (var cap in d.Capabilities.Take(3))
                                {
                                    <span class="badge bg-light text-secondary border me-1" style="font-size:.7rem;">@cap.Key</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-name="@d.Name"
                                   class="btn btn-sm btn-outline-secondary">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
