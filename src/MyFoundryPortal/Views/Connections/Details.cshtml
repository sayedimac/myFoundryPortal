@model MyFoundryPortal.ViewModels.ConnectionViewModel
@{
    ViewData["Title"] = Model.Name;
    var iconClass = Model.ConnectionType switch
    {
        "AzureOpenAI" => "bi-stars",
        "AzureAISearch" => "bi-search",
        "AzureAIServices" => "bi-cpu",
        "AzureBlobStorage" => "bi-archive",
        "Serverless" => "bi-lightning-charge",
        _ => "bi-plug",
    };
}

<div class="portal-page-header d-flex align-items-center gap-2">
    <a asp-action="Index" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div class="d-flex align-items-center gap-3 flex-grow-1">
        <div class="portal-card-icon flex-shrink-0">
            <i class="bi @iconClass"></i>
        </div>
        <div>
            <h1 class="portal-page-title">@Model.Name</h1>
            <p class="text-muted small mb-0">Connection Details · <span class="portal-badge portal-badge-model">@Model.ConnectionType</span></p>
        </div>
    </div>
    @if (Model.IsDefault)
    {
        <span class="badge bg-success-subtle text-success border border-success-subtle">Default connection</span>
    }
</div>

<div class="portal-page-content">

    @if (ViewData["Error"] != null)
    {
        <div class="alert alert-warning small">@ViewData["Error"]</div>
    }

    <div class="row g-3">
        <div class="col-md-8">
            <div class="bg-white rounded border p-4">
                <h5 class="mb-3 fw-semibold">Connection Information</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted small">Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Name</dd>

                    <dt class="col-sm-4 text-muted small">Type</dt>
                    <dd class="col-sm-8">
                        <span class="portal-badge portal-badge-model">@Model.ConnectionType</span>
                    </dd>

                    <dt class="col-sm-4 text-muted small">Endpoint / Target</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.Target))
                        {
                            <code class="small" style="word-break:break-all;">@Model.Target</code>
                        }
                        else
                        {
                            <span class="text-muted">–</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted small">Authentication</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-light text-secondary border">
                            <i class="bi bi-key me-1"></i>@Model.AuthType
                        </span>
                    </dd>

                    <dt class="col-sm-4 text-muted small">Default</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsDefault)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Yes</span>
                        }
                        else
                        {
                            <span class="text-muted">No</span>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Id))
                    {
                        <dt class="col-sm-4 text-muted small">Resource ID</dt>
                        <dd class="col-sm-8">
                            <code class="small" style="word-break:break-all;font-size:.75rem;">@Model.Id</code>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        <div class="col-md-4">
            <div class="config-notice h-100">
                <h6 class="fw-semibold mb-2">
                    <i class="bi bi-info-circle me-1 text-primary"></i>How Agents Use Connections
                </h6>
                @switch (Model.ConnectionType)
                {
                    case "AzureOpenAI":
                        <p class="small text-muted mb-0">
                            <strong>Azure OpenAI</strong> connections provide model deployments (GPT-4o, embeddings, etc.)
                            that agents use for inference. The Foundry SDK routes requests through this connection
                            automatically when you specify a deployment by name.
                        </p>
                        break;
                    case "AzureAISearch":
                        <p class="small text-muted mb-0">
                            <strong>Azure AI Search</strong> connections power the <em>File Search</em> tool
                            and RAG (Retrieval-Augmented Generation) scenarios. Agents with File Search enabled
                            query this index to ground their responses in your documents.
                        </p>
                        break;
                    case "AzureBlobStorage":
                        <p class="small text-muted mb-0">
                            <strong>Blob Storage</strong> connections are used to upload files for the Code Interpreter
                            and File Search tools. The Foundry SDK manages file chunking, indexing, and retrieval
                            against this storage account.
                        </p>
                        break;
                    case "Serverless":
                        <p class="small text-muted mb-0">
                            <strong>Serverless</strong> connections expose pay-as-you-go model endpoints from the
                            Azure AI Model Catalog. These can be used as model backends for agents without
                            provisioned capacity.
                        </p>
                        break;
                    default:
                        <p class="small text-muted mb-0">
                            This connection makes an external Azure service available to your Foundry project.
                            Agents and pipelines can reference it by name to access its capabilities.
                        </p>
                        break;
                }
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Connections
        </a>
    </div>
</div>
