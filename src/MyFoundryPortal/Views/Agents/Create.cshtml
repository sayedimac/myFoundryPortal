@model MyFoundryPortal.ViewModels.CreateAgentViewModel
@{
    ViewData["Title"] = "Create Agent";
}

<div class="portal-page-header d-flex align-items-center gap-2">
    <a asp-action="Index" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="portal-page-title">Create Agent</h1>
        <p class="text-muted small mb-0">Register a new persistent agent in your Foundry project</p>
    </div>
</div>

<div class="portal-page-content">
    <div class="row">
        <div class="col-lg-7">
            <div class="bg-white rounded border p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold small">Agent Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-sm" placeholder="e.g. my-assistant" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Model" class="form-label fw-semibold small">Model Deployment <span class="text-danger">*</span></label>
                        @if (Model.AvailableModels.Count > 0)
                        {
                            <select asp-for="Model" class="form-select form-select-sm">
                                <option value="">— select a deployment —</option>
                                @foreach (var m in Model.AvailableModels)
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input asp-for="Model" class="form-control form-control-sm"
                                   placeholder="e.g. gpt-4o" />
                            <div class="form-text text-muted">
                                Enter the deployment name (could not enumerate deployments automatically).
                            </div>
                        }
                        <span asp-validation-for="Model" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold small">Description</label>
                        <input asp-for="Description" class="form-control form-control-sm"
                               placeholder="Optional short description of what this agent does" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Instructions" class="form-label fw-semibold small">
                            Instructions <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Instructions" class="form-control form-control-sm"
                                  rows="6" placeholder="You are a helpful assistant…"></textarea>
                        <div class="form-text text-muted">
                            System instructions that define the agent's persona and behavior.
                        </div>
                        <span asp-validation-for="Instructions" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-foundry btn-sm px-4">
                            <i class="bi bi-plus me-1"></i>Create Agent
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="config-notice">
                <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle me-1 text-primary"></i>About Agents</h6>
                <p class="small text-muted mb-2">
                    Persistent Agents are AI assistants backed by a model deployment.
                    They maintain conversation history through threads and can be equipped with tools.
                </p>
                <ul class="small text-muted mb-0">
                    <li>Choose a deployed model from your project</li>
                    <li>Write clear, specific system instructions</li>
                    <li>Use the Playground to test your agent</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
